{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/tdd-guardrail.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/review-reply-protocol.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "coderabbit@claude-plugins-official": true,
    "bushido@han": true,
    "core@han": true,
    "ralph-loop@claude-plugins-official": true,
    "claude-agent-sdk@han": true,
    "clippy@han": true,
    "helm@han": true,
    "rust@han": true,
    "backend-development@han": true,
    "bdd@han": true,
    "tdd@han": true,
    "kubernetes@han": true,
    "blueprints@han": true
  },
  "extraKnownMarketplaces": {
    "han": {
      "source": {
        "source": "github",
        "repo": "thebushidocollective/han"
      }
    }
  }
}
