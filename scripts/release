#!/usr/bin/env bash
set -euo pipefail

usage() {
  printf 'usage: scripts/release <prepare|publish> --workspace <path> --version <version> [--date <date>] [--dry-run]\n' >&2
}

command="${1:-}"
if [[ -z "$command" ]]; then
  usage
  exit 2
fi
shift

workspace="."
version=""
date=""
dry_run=false

release_notes_file() {
  local changelog="$1"
  local requested_version="$2"
  local notes_file

  notes_file="$(mktemp)"
  awk -v heading="## [$requested_version]" '
    index($0, heading) == 1 { in_notes = 1; next }
    in_notes && /^## \[/ { exit }
    in_notes { print }
  ' "$changelog" >"$notes_file"
  printf '%s\n' "$notes_file"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --workspace)
      workspace="${2:-}"
      shift 2
      ;;
    --version)
      version="${2:-}"
      shift 2
      ;;
    --date)
      date="${2:-}"
      shift 2
      ;;
    --dry-run)
      dry_run=true
      shift
      ;;
    *)
      usage
      exit 2
      ;;
  esac
done

if [[ -z "$version" ]]; then
  usage
  exit 2
fi

if [[ ! "$version" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
  printf 'release version must be semantic x.y.z\n' >&2
  exit 2
fi

case "$command" in
  prepare)
    if [[ -z "$date" ]]; then
      date="$(date +%F)"
    fi
    if [[ "$dry_run" == true ]]; then
      printf '+version = "%s"\n' "$version"
      printf '+## [%s] - %s\n' "$version" "$date"
      exit 0
    fi
    python3 - "$workspace" "$workspace/Cargo.toml" "$workspace/CHANGELOG.md" "$workspace/Cargo.lock" "$version" "$date" <<'PY'
import pathlib
import re
import subprocess
import sys

workspace = pathlib.Path(sys.argv[1])
cargo_toml = pathlib.Path(sys.argv[2])
changelog = pathlib.Path(sys.argv[3])
cargo_lock = pathlib.Path(sys.argv[4])
version = sys.argv[5]
date = sys.argv[6]


def git_output(*args):
    return subprocess.check_output(
        ["git", "-C", str(workspace), *args],
        stderr=subprocess.DEVNULL,
        text=True,
    )


def previous_release_tag():
    try:
        return git_output("describe", "--tags", "--match", "v[0-9]*", "--abbrev=0").strip()
    except (subprocess.CalledProcessError, FileNotFoundError):
        return ""


def commits_since_previous_release():
    tag = previous_release_tag()
    revision = f"{tag}..HEAD" if tag else "HEAD"
    try:
        raw = git_output("log", "--no-show-signature", "--reverse", "--format=%s%x00%B%x1e", revision)
    except (subprocess.CalledProcessError, FileNotFoundError):
        return []
    commits = []
    for record in raw.split("\x1e"):
        record = record.strip("\n")
        if not record:
            continue
        subject, _, body = record.partition("\x00")
        commits.append((subject.strip(), body))
    return commits


def release_notes():
    headings = [
        ("feat", "Added"),
        ("changed", "Changed"),
        ("deprecated", "Deprecated"),
        ("fix", "Fixed"),
        ("security", "Security"),
        ("other", "Other"),
    ]
    grouped = {key: [] for key, _ in headings}
    conventional = re.compile(r"^(?P<kind>[a-zA-Z]+)(?:\((?P<scope>[^)]+)\))?(?P<breaking>!)?: (?P<message>.+)$")
    for subject, body in commits_since_previous_release():
        match = conventional.match(subject)
        if match:
            kind = match.group("kind").lower()
            scope = match.group("scope")
            breaking = bool(match.group("breaking")) or "BREAKING CHANGE:" in body
            message = match.group("message")
        else:
            kind = "other"
            scope = None
            breaking = "BREAKING CHANGE:" in body
            message = subject
        bucket = kind if kind in grouped and kind != "other" else "other"
        parts = ["-"]
        if breaking:
            parts.append("[**breaking**]")
        if scope:
            parts.append(f"*({scope})*")
        parts.append(message)
        grouped[bucket].append(" ".join(parts))
    lines = []
    for key, heading in headings:
        if grouped[key]:
            lines.extend([f"### {heading}", "", *grouped[key], ""])
    return "\n".join(lines).rstrip()

cargo_text = cargo_toml.read_text()
updated_cargo, replacements = re.subn(
    r'(?m)^(version\s*=\s*")[^"]+("\s*)$',
    rf'\g<1>{version}\2',
    cargo_text,
    count=1,
)
if replacements != 1:
    raise SystemExit('workspace package version not found')
cargo_toml.write_text(updated_cargo)

if cargo_lock.exists():
    lock_text = cargo_lock.read_text()
    lock_parts = lock_text.split('[[package]]')
    updated_parts = [lock_parts[0]]
    for package in lock_parts[1:]:
        name_match = re.search(r'(?m)^name\s*=\s*"([^"]+)"', package)
        if name_match and name_match.group(1).startswith('ar-'):
            package = re.sub(
                r'(?m)^(version\s*=\s*")[^"]+("\s*)$',
                rf'\g<1>{version}\2',
                package,
                count=1,
            )
        updated_parts.append(package)
    cargo_lock.write_text('[[package]]'.join(updated_parts))

changelog_text = changelog.read_text()
notes = release_notes()
release_section = f'## [{version}] - {date}'
if notes:
    release_section = f'{release_section}\n\n{notes}'
changelog.write_text(changelog_text.replace('## [Unreleased]', f'## [Unreleased]\n\n{release_section}', 1))
PY
    ;;
  publish)
    if [[ "${FORGEJO_EVENT_NAME:-}" != "pull_request" || "${FORGEJO_EVENT_ACTION:-}" != "closed" || "${FORGEJO_PULL_REQUEST_HEAD_BRANCH:-}" != "release/v$version" ]]; then
      printf 'release publish must run from a closed release PR\n' >&2
      exit 1
    fi
    if [[ "${FORGEJO_PULL_REQUEST_MERGED:-}" != "true" ]]; then
      printf 'release PR has not been merged\n' >&2
      exit 1
    fi
    if [[ -n "${FORGEJO_PULL_REQUEST_BASE_BRANCH:-}" && "${FORGEJO_PULL_REQUEST_BASE_BRANCH:-}" != "main" ]]; then
      printf 'release PR was not merged into main\n' >&2
      exit 1
    fi
    if [[ "$dry_run" == true ]]; then
      printf 'git tag -a v%s\n' "$version"
      printf 'tea release create --tag v%s\n' "$version"
      exit 0
    fi
    if [[ -z "${FORGEJO_TOKEN:-}" ]]; then
      printf 'missing FORGEJO_TOKEN\n' >&2
      exit 1
    fi
    : "${GITEA_SERVER_URL:=https://git.johnwilger.com}"
    : "${GITEA_SERVER_TOKEN:=$FORGEJO_TOKEN}"
    notes_file="$(release_notes_file "$workspace/CHANGELOG.md" "$version")"
    git -C "$workspace" tag -a "v$version" -m "Release v$version"
    git -C "$workspace" \
      -c 'credential.helper=!f() { printf "username=release\npassword=%s\n" "$FORGEJO_TOKEN"; }; f' \
      push origin "v$version"
    tea login add --name auto_review-release --url "$GITEA_SERVER_URL" --token "$GITEA_SERVER_TOKEN"
    tea release create --repo jwilger/auto_review --tag "v$version" --note-file "$notes_file"
    ;;
  *)
    usage
    exit 2
    ;;
esac
