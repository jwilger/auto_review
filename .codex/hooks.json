{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env python3 \"$(git rev-parse --show-toplevel)/scripts/codex/pre_tool_use.py\"",
            "timeout": 30,
            "statusMessage": "Checking auto_review Codex policy"
          }
        ]
      }
    ]
  }
}
