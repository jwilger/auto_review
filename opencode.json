{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".opencode/rules/*.md"
  ],
  "model": "openai/gpt-5.3-codex-spark",
  "default_agent": "build",
  "plugin": [
    "opencode-rtk"
  ],
  "agent": {
    "build": {
      "model": "openai/gpt-5.3-codex-spark"
    },
    "plan": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "high"
    },
    "rgr-test-author": {
      "model": "openai/gpt-5.3-codex-spark"
    },
    "rgr-test-reviewer": {
      "model": "openai/gpt-5.3-codex-spark"
    },
    "rgr-implementation-reviewer": {
      "model": "openai/gpt-5.3-codex-spark"
    },
    "rgr-diagnostic-implementer": {
      "model": "openai/gpt-5.3-codex-spark"
    },
    "test-coverage-reviewer": {
      "model": "openai/gpt-5.3-codex-spark"
    },
    "docs-operator-reviewer": {
      "model": "openai/gpt-5.3-codex-spark"
    },
    "forgejo-feedback-processor": {
      "model": "openai/gpt-5.3-codex-spark"
    },
    "architecture-reviewer": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "high"
    },
    "security-reviewer": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "high"
    },
    "plan-advisor": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "high"
    }
  },
  "mcp": {
    "forgejo": {
      "type": "local",
      "command": [
        "sh",
        "-lc",
        "exec nix develop . --command forgejo-mcp --transport stdio --url https://git.johnwilger.com --token \"$FORGEJO_TOKEN\" --user-agent auto_review/forgejo-mcp"
      ],
      "environment": {
        "FORGEJO_USER_AGENT": "auto_review/forgejo-mcp"
      },
      "enabled": true,
      "timeout": 10000
    }
  },
  "lsp": {
    "rust": {
      "command": [
        "nix",
        "develop",
        ".",
        "--command",
        "rust-analyzer"
      ],
      "extensions": [
        ".rs"
      ],
      "initialization": {
        "cargo": {
          "allFeatures": true
        },
        "check": {
          "command": "clippy"
        }
      }
    }
  },
  "skills": {
    "paths": [
      ".opencode/skills"
    ]
  },
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "task": "allow",
    "skill": "allow",
    "todowrite": "allow",
    "lsp": "allow",
    "bash": "allow",
    "edit": {
      ".env": "deny",
      ".env.*": "deny",
      "**/*secret*": "ask",
      "**/*credential*": "ask",
      "**/*.key": "deny",
      "**/*.pem": "deny",
      "*": "allow"
    },
    "external_directory": "ask",
    "forgejo_*": {
      "*": "allow"
    }
  },
  "compaction": {
    "auto": true,
    "prune": true
  },
  "snapshot": true,
  "share": "manual"
}
