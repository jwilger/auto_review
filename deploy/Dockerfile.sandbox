# syntax=docker/dockerfile:1.7
#
# auto_review sandbox image.
#
# Bundles the 12 linter binaries the review pipeline currently invokes,
# so they can be exec'd by `podman run --rm --network=none --read-only ...`
# from the gateway. Push this somewhere podman on the gateway host can
# pull (`docker.io/...`, `ghcr.io/...`, or your private registry) and
# point AR_SANDBOX_IMAGE at it.
#
# This image is intentionally NOT the gateway image — keeping the two
# separate means the rootfs the linters see contains only what they
# need, and a sandbox-escape doesn't grant access to the gateway's
# Forgejo token / LLM creds / learnings DB.
#
# Linter set (in alphabetical order):
#   actionlint, ansible-lint, ast-grep, bandit, biome, buf, checkov,
#   cppcheck, dotenv-linter, eslint, gitleaks, golangci-lint, gosec,
#   hadolint, kubeconform, markdownlint, mypy, osv-scanner, oxlint,
#   phpstan, pmd, rubocop, ruff, semgrep, shellcheck, sqlfluff,
#   staticcheck, swiftlint, taplo, tflint, trivy, typos, vale,
#   yamllint
#
# All entrypoints stay on PATH so the orchestrator can invoke them by
# bare name (e.g. `ruff`, `shellcheck`).

FROM debian:bookworm-slim

ARG TARGETARCH=amd64

RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates curl git unzip \
        # debian-packaged linters
        shellcheck \
        yamllint \
        cppcheck \
        # interpreters used by linters that ship as scripts
        nodejs npm \
        python3 python3-pip \
        ruby \
        php-cli composer \
        default-jre \
    && rm -rf /var/lib/apt/lists/*

# Python linters (pip)
RUN pip3 install --break-system-packages \
        ruff \
        semgrep \
        sqlfluff \
        checkov \
        mypy \
        bandit \
        ansible-lint

# Ruby linters (gem)
RUN gem install --no-document rubocop

# PHP linters (composer global, then symlink to PATH)
RUN composer global require --no-interaction --quiet phpstan/phpstan \
    && ln -sf /root/.composer/vendor/bin/phpstan /usr/local/bin/phpstan

# Node linters (npm)
RUN npm install -g \
        eslint \
        markdownlint-cli \
        @biomejs/biome \
        oxlint

# Static-binary linters: pin the latest release downloads.
RUN set -eux; \
    curl -fsSL "https://github.com/hadolint/hadolint/releases/latest/download/hadolint-Linux-x86_64" \
        -o /usr/local/bin/hadolint && chmod +x /usr/local/bin/hadolint; \
    curl -fsSL "https://github.com/rhysd/actionlint/releases/latest/download/actionlint_linux_${TARGETARCH}.tar.gz" \
        | tar -xz -C /usr/local/bin actionlint; \
    curl -fsSL "https://github.com/zricethezav/gitleaks/releases/latest/download/gitleaks_8.22.1_linux_x64.tar.gz" \
        | tar -xz -C /usr/local/bin gitleaks; \
    curl -fsSL "https://github.com/golangci/golangci-lint/releases/latest/download/golangci-lint-1.64.5-linux-${TARGETARCH}.tar.gz" \
        | tar -xz -C /tmp \
        && mv /tmp/golangci-lint-1.64.5-linux-${TARGETARCH}/golangci-lint /usr/local/bin/; \
    curl -fsSL "https://github.com/securego/gosec/releases/latest/download/gosec_2.21.4_linux_amd64.tar.gz" \
        | tar -xz -C /usr/local/bin gosec; \
    curl -fsSL "https://github.com/dominikh/go-tools/releases/latest/download/staticcheck_linux_amd64.tar.gz" \
        | tar -xz -C /tmp \
        && mv /tmp/staticcheck/staticcheck /usr/local/bin/ \
        && rm -rf /tmp/staticcheck; \
    curl -fsSL "https://github.com/terraform-linters/tflint/releases/latest/download/tflint_linux_amd64.zip" \
        -o /tmp/tflint.zip \
        && unzip -q /tmp/tflint.zip -d /tmp/tflint \
        && mv /tmp/tflint/tflint /usr/local/bin/ \
        && rm -rf /tmp/tflint /tmp/tflint.zip; \
    curl -fsSL "https://github.com/aquasecurity/trivy/releases/latest/download/trivy_0.59.0_Linux-64bit.tar.gz" \
        | tar -xz -C /usr/local/bin trivy; \
    curl -fsSL "https://github.com/google/osv-scanner/releases/latest/download/osv-scanner_linux_${TARGETARCH}" \
        -o /usr/local/bin/osv-scanner; \
    curl -fsSL "https://github.com/ast-grep/ast-grep/releases/latest/download/app-x86_64-unknown-linux-gnu.zip" \
        -o /tmp/ast-grep.zip \
        && unzip -q /tmp/ast-grep.zip -d /tmp/ast-grep \
        && mv /tmp/ast-grep/ast-grep /usr/local/bin/ \
        && rm -rf /tmp/ast-grep /tmp/ast-grep.zip; \
    curl -fsSL "https://github.com/tamasfe/taplo/releases/latest/download/taplo-full-linux-x86_64.gz" \
        | gunzip > /usr/local/bin/taplo; \
    curl -fsSL "https://github.com/dotenv-linter/dotenv-linter/releases/latest/download/dotenv-linter-linux-x86_64.tar.gz" \
        | tar -xz -C /usr/local/bin dotenv-linter; \
    curl -fsSL "https://github.com/yannh/kubeconform/releases/latest/download/kubeconform-linux-amd64.tar.gz" \
        | tar -xz -C /usr/local/bin kubeconform; \
    curl -fsSL "https://github.com/errata-ai/vale/releases/latest/download/vale_3.7.1_Linux_64-bit.tar.gz" \
        | tar -xz -C /usr/local/bin vale; \
    curl -fsSL "https://github.com/realm/SwiftLint/releases/latest/download/swiftlint_linux.zip" \
        -o /tmp/swiftlint.zip \
        && unzip -q /tmp/swiftlint.zip -d /tmp/swiftlint \
        && mv /tmp/swiftlint/swiftlint /usr/local/bin/ \
        && rm -rf /tmp/swiftlint /tmp/swiftlint.zip; \
    curl -fsSL "https://github.com/bufbuild/buf/releases/latest/download/buf-Linux-x86_64" \
        -o /usr/local/bin/buf; \
    curl -fsSL "https://github.com/crate-ci/typos/releases/latest/download/typos-v1.27.0-x86_64-unknown-linux-musl.tar.gz" \
        | tar -xz -C /usr/local/bin ./typos; \
    curl -fsSL "https://github.com/pmd/pmd/releases/download/pmd_releases%2F7.0.0/pmd-dist-7.0.0-bin.zip" \
        -o /tmp/pmd.zip \
        && unzip -q /tmp/pmd.zip -d /opt \
        && ln -sf /opt/pmd-bin-7.0.0/bin/pmd /usr/local/bin/pmd \
        && rm /tmp/pmd.zip; \
    chmod +x /usr/local/bin/*

# Linters never need to write to the rootfs.
USER 65534:65534
WORKDIR /work

# No CMD: the gateway invokes the linter binary by name. ENTRYPOINT
# left empty so the orchestrator's argv passes through unchanged.
