{
  "$schema": "https://app.kilo.ai/config.json",
  "instructions": [
    "AGENTS.md",
    ".kilo/rules/*.md"
  ],
  "default_agent": "auto-review-rust-implementer",
  "plugin": [
    "kilo-rtk@npm:@jwilger/kilo-rtk"
  ],
  "mcp": {
    "forgejo": {
      "type": "local",
      "command": [
        "sh",
        "-lc",
        "exec forgejo-mcp --transport stdio --url https://git.johnwilger.com --token \"$FORGEJO_TOKEN\" --user-agent auto_review/forgejo-mcp"
      ],
      "environment": {
        "FORGEJO_USER_AGENT": "auto_review/forgejo-mcp"
      },
      "enabled": true,
      "timeout": 10000
    }
  },
  "skills": {
    "paths": [".kilo/skills"]
  },
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "task": "allow",
    "skill": "allow",
    "todowrite": "allow",
    "bash": "allow",
    "edit": {
      ".env": "deny",
      ".env.*": "deny",
      "**/*secret*": "ask",
      "**/*credential*": "ask",
      "**/*.key": "deny",
      "**/*.pem": "deny",
      "*": "allow"
    },
    "external_directory": "ask"
  },
  "compaction": {
    "auto": true,
    "prune": true
  },
  "snapshot": true,
  "share": "manual"
}
